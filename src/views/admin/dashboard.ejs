<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - simplecms</title>
    <link rel="stylesheet" href="/public/style.css" />
  </head>
  <body class="yi-admin-body">
    <div class="yi-admin-shell">
      <aside class="yi-admin-sidebar">
        <a href="/admin" class="yi-admin-logo">壹影视 CMS</a>
        <nav class="yi-admin-nav">
          <a href="/admin" class="is-active">仪表盘</a>
          <a href="/admin/sources">采集源管理</a>
          <a href="/admin/collect/search">全站搜索</a>
          <a href="/admin/videos">资源管理</a>
          <a href="/admin/logs">采集日志</a>
          <a href="/">返回前台</a>
        </nav>
        <a href="/admin/logout" class="yi-admin-logout">退出登录</a>
      </aside>

      <main class="yi-admin-main">
        <header class="yi-admin-header">
          <div>
            <h1>采集后台</h1>
            <p>当前管理员：<%= admin.username %></p>
          </div>
        </header>

        <section class="yi-admin-stats" style="margin-bottom: 16px">
          <article class="yi-admin-card yi-admin-stat"><strong><%= sourceCount %></strong><span>采集源</span></article>
          <article class="yi-admin-card yi-admin-stat"><strong><%= categoryCount %></strong><span>分类数</span></article>
          <article class="yi-admin-card yi-admin-stat"><strong><%= videoCount %></strong><span>视频数</span></article>
        </section>

        <section class="yi-admin-card yi-admin-panel">
          <div class="yi-admin-panel-title">
            <h2>最近采集日志</h2>
          </div>
          <div class="table-wrap yi-admin-table-wrap">
            <table class="yi-admin-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>来源</th>
                  <th>状态</th>
                  <th>新增/更新/跳过</th>
                  <th>详情</th>
                  <th>时间</th>
                </tr>
              </thead>
              <tbody>
                <% latestLogs.forEach((log) => { %>
                  <tr>
                    <td>#<%= log.id %></td>
                    <td><%= log.sourceName %></td>
                    <td>
                      <% if (log.status === 'success') { %>
                        <span class="tag tag-ok">成功</span>
                      <% } else { %>
                        <span class="tag tag-fail">失败</span>
                      <% } %>
                    </td>
                    <td><%= log.importedCount %>/<%= log.updatedCount %>/<%= log.skippedCount %></td>
                    <td><%= log.detail || '' %></td>
                    <td><%= log.createdAt.toLocaleString('zh-CN') %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
