<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - Simplecms</title>
    <link rel="stylesheet" href="/public/style.css" />
  </head>
  <body class="yi-admin-body">
    <div class="yi-admin-layout yi-admin-shell">
      <aside class="yi-admin-sidebar">
        <a href="/admin" class="yi-admin-logo">Simple CMS</a>
        <nav class="yi-admin-nav">
          <a href="/admin" class="is-active">仪表盘</a>
          <a href="/admin/sources">采集源管理</a>
          <a href="/admin/collect/search">全站搜索</a>
          <a href="/admin/videos">资源管理</a>
          <a href="/admin/logs">采集日志</a>
        </nav>
        <div class="yi-admin-side-actions">
          <a href="/" class="yi-admin-return-front">返回前台</a>
          <a href="/admin/logout" class="yi-admin-logout">退出登录</a>
        </div>
      </aside>

      <main class="yi-admin-main">
        <header class="yi-admin-header">
          <div>
            <h1>运营仪表盘</h1>
            <p>当前管理员：<%= admin.username %> · 聚焦“状态概览 + 今日产出”，详细流水请前往采集日志页</p>
          </div>
          <span class="yi-admin-chip">operations overview</span>
        </header>

        <section class="yi-admin-stats" style="margin-bottom: 16px">
          <article class="yi-admin-card yi-admin-stat">
            <strong><%= sourceCount %></strong>
            <span>采集源总数（启用 <%= enabledSourceCount %>）</span>
          </article>
          <article class="yi-admin-card yi-admin-stat">
            <strong><%= runningTaskCount %></strong>
            <span>运行中任务</span>
          </article>
          <article class="yi-admin-card yi-admin-stat">
            <strong><%= videoCount %></strong>
            <span>累计视频（分类 <%= categoryCount %>）</span>
          </article>
        </section>

        <section class="yi-admin-card yi-admin-panel" style="margin-bottom: 16px">
          <div class="yi-admin-panel-title">
            <h2>今日采集简报</h2>
            <span class="yi-admin-chip">today</span>
          </div>
          <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(168px, 1fr)); gap:12px;">
            <div class="yi-admin-kpi-item"><strong><%= todayLogsCount %></strong><span>任务次数</span></div>
            <div class="yi-admin-kpi-item"><strong><%= todaySuccessCount %></strong><span>成功任务</span></div>
            <div class="yi-admin-kpi-item"><strong><%= todayFailedCount %></strong><span>失败任务</span></div>
            <div class="yi-admin-kpi-item"><strong><%= todayImported %></strong><span>今日新增</span></div>
            <div class="yi-admin-kpi-item"><strong><%= todayUpdated %></strong><span>今日更新</span></div>
            <div class="yi-admin-kpi-item">
              <strong><%= todayLogsCount ? Math.round((todaySuccessCount / todayLogsCount) * 100) : 0 %>%</strong>
              <span>成功率</span>
            </div>
          </div>
        </section>

        <section class="yi-admin-card yi-admin-panel" style="margin-bottom: 16px">
          <div class="yi-admin-panel-title">
            <h2>分类数据分布</h2>
            <span class="yi-admin-chip">compact chart</span>
          </div>
          <% if (Array.isArray(categoryVideoStats) && categoryVideoStats.length) { %>
            <% const maxCount = Math.max(...categoryVideoStats.map((item) => Number(item.videoCount || 0)), 1); %>
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap:12px;">
              <% categoryVideoStats.forEach((item) => { %>
                <% const count = Number(item.videoCount || 0); %>
                <% const ratio = videoCount > 0 ? Math.round((count / Number(videoCount || 1)) * 100) : 0; %>
                <% const width = Math.max(4, Math.round((count / maxCount) * 100)); %>
                <div style="border:1px solid #1f2937; border-radius:10px; padding:10px 12px; background:#0f172a;">
                  <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; margin-bottom:8px;">
                    <div style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= item.name %>"><%= item.name %></div>
                    <strong style="flex:0 0 auto;"><%= count %></strong>
                  </div>
                  <div style="position:relative; height:10px; border-radius:999px; background:#1f2937; overflow:hidden;">
                    <span
                      class="yi-dashboard-bar-fill"
                      data-width="<%= width %>"
                      style="position:absolute; left:0; top:0; bottom:0; width:0; background:linear-gradient(90deg,#6366f1,#14b8a6);"
                    ></span>
                  </div>
                  <div class="yi-collect-hint" style="margin-top:6px; text-align:right;">占比 <%= ratio %>%</div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="yi-empty">暂无分类数据。</div>
          <% } %>
        </section>

      </main>
    </div>

    <script>
      (function () {
        const bars = document.querySelectorAll('.yi-dashboard-bar-fill');
        bars.forEach((bar) => {
          const width = Math.max(0, Math.min(100, Number(bar.getAttribute('data-width') || 0)));
          bar.style.width = width + '%';
        });
      })();
    </script>
  </body>
</html>
